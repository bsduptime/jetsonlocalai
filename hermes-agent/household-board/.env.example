# hermes-household-board — /etc/hermes-household-board/.env
# Owned root:hermes, mode 0640 (the service runs as hermes and must read it;
# nobody else needs to).

# BotFather token for the DEDICATED board bot (NOT Elena's token — two
# pollers on one token conflict). Privacy mode can stay ON: the board only
# needs /list commands and button taps, never chat messages.
HOUSEHOLD_BOT_TOKEN=

# Comma-separated Telegram chat ids allowed to have boards. FAIL CLOSED:
# while empty the service runs in DISCOVERY MODE — serves no chat, but logs
# the chat id of every /list attempt. So: leave empty, start the service,
# send /list in each target chat, copy the ids from
# `journalctl -u hermes-household-board`, paste here, restart.
HOUSEHOLD_ALLOWED_CHAT_IDS=

# Must resolve to the SAME dir the household plugin uses. The plugin
# defaults to $HERMES_HOME/household; the unit sets HERMES_HOME already, so
# normally leave this unset.
#HOUSEHOLD_STATE_DIR=

# getUpdates long-poll seconds (also bounds how stale the board can be
# after Elena writes the store). Default 10.
#HOUSEHOLD_POLL_TIMEOUT=10
