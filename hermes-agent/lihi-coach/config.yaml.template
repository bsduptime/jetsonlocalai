# ~/.hermes/config.yaml template for the hermes-lihi instance (Noga, Lihi's
# CMO coach). Installed by setup-lihi-coach.sh; placeholders marked TODO.
# The LLM provider block is created interactively by `hermes setup` (run as
# hermes-lihi) and merged by hermes itself — this template only pins the
# coach-specific keys.

telegram:
  enabled: true
  # Fail-closed allowlist: ONLY these Telegram user IDs can talk to Noga.
  # Get an ID by messaging @userinfobot from each account.
  allow_from:
    - "TODO_LIHI_TELEGRAM_USER_ID"
    - "TODO_DAVID_TELEGRAM_USER_ID"

stt:
  # Route all audio through the local jetson-stt service (Hebrew/English
  # detect-then-route, whisper-large-v3-turbo). See /mnt/sdcard/jetson-stt.
  provider: jetson
  providers:
    jetson:
      type: command
      command: "/mnt/sdcard/jetson-stt/stt-client {input_path} {output_path}"
      format: txt
      # hour-long recordings at ~1.9x realtime CPU need a generous ceiling
      timeout: 3600

# The coach files everything into the marketing repo (bound into the sandbox
# at this path) — SOUL.md carries the conventions.
