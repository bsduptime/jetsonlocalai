# hermes-greeninvoice — daemon configuration.
# Lives at /etc/hermes-greeninvoice/.env on the host.
# Owned root:hermes-greeninvoice-config, mode 0640. The dynamic daemon
# user reads it via that group. David edits it via a per-file ACL (no
# sudo). The hermes user (Elena) has NO access — that's the whole point.

# ===== Environment ==========================================================

# sandbox | production. Start with sandbox so nothing touches real tax
# records. GI_BASE_URL can override the derived URL if ever needed.
GI_ENV=sandbox

# Hard safety belt: while true, the daemon validates + rate-limits + audits
# but NEVER calls the live GreenInvoice API (returns synthetic results).
# Flip to false ONLY once sandbox creds are in and you've watched it work.
GI_DRY_RUN=true

# ===== Credentials ==========================================================
# Generate at: GreenInvoice dashboard -> Settings -> Developer Tools -> API Keys
# (sandbox: app.sandbox.d.greeninvoice.co.il). Required once GI_DRY_RUN=false.
# GI_API_KEY_ID=
# GI_API_KEY_SECRET=

# ===== Rate limits (per caller, per action class) ===========================
# Each class has an hourly and a daily cap. Both must be under to admit a call.
#   issue        — create a real, irreversible document (305/320/400). TIGHT.
#   draft        — render a preview (no record, no email). LOOSE.
#   client_write — create/update a client. LOOSE.
# Reads (get/search/download-links) are never limited.

GI_LIMIT_TZ=local

# Defaults shown; uncomment to override.
# GI_LIMIT_ISSUE_PER_HOUR=3
# GI_LIMIT_ISSUE_PER_DAY=10
# GI_LIMIT_DRAFT_PER_HOUR=20
# GI_LIMIT_DRAFT_PER_DAY=60
# GI_LIMIT_CLIENT_WRITE_PER_HOUR=20
# GI_LIMIT_CLIENT_WRITE_PER_DAY=100

# How long a reserved-but-unfinalized slot lingers before the reaper
# reclassifies it (counts against quota — conservative).
# GI_RESERVATION_TTL_SECONDS=120

# ===== Preview PDFs =========================================================
# Drafts render a PDF. Rather than return it as base64 (which bloats the
# agent's context), the daemon writes it to a file under the runtime dir
# (/run/hermes-greeninvoice/previews) and returns preview_pdf_path instead.
# The file is group-readable by hermes-greeninvoice-clients so the agent can
# attach/send it. Ephemeral (tmpfs); pruned by age + count.
# GI_SPOOL_PREVIEWS=true
# GI_PREVIEW_RETENTION_SECONDS=3600
# GI_PREVIEW_MAX_FILES=50
# To email a preview via the mailer, add this dir to that plugin's
# EMAIL_ATTACHMENT_ALLOWED_PREFIXES=/tmp/:/run/hermes-greeninvoice/previews/

# ===== HTTP =================================================================
# GI_HTTP_TIMEOUT_SECONDS=30
# Client-side throttle: min gap between API calls (~3 req/s ceiling).
# GI_MIN_REQUEST_INTERVAL_MS=350

# ===== Caller-UID map (future-proofing for multi-tenant) ====================
# Maps connecting Unix UID -> caller identity (SO_PEERCRED, kernel-attested,
# unspoofable). Without an entry, only "hermes" maps to "elena"; all else is
# rejected as unknown_caller.
#   CALLER_UID_winnow_agent=1234

# ===== TCP mode (Windows — no AF_UNIX) ======================================
# HERMES_GREENINVOICE_SOCKET=tcp://127.0.0.1:8766
# TCP has no kernel peer credentials, so identity is a per-caller shared
# secret instead. The daemon REFUSES all TCP requests until at least one
# token is configured (fail closed). >= 16 chars; generate with:
#   python -c "import secrets; print(secrets.token_hex(24))"
# Each agent gets its OWN token -> its own audit identity + rate buckets.
#   GI_CALLER_TOKEN_elena=<secret>
# The matching client env (on the Hermes side): HERMES_GREENINVOICE_TOKEN.
# Loopback only — the daemon refuses to bind a routable address.
