# hermes-mailer — daemon configuration.
# Lives at /etc/hermes-mailer/.env on the host.
# Mode 600 owned by root. ACL grants `dbexpertai` r/w so david can edit
# without sudo. The dynamic `hermes-mailer` user (the daemon) gets read
# access via systemd's ConfigurationDirectory mechanism.
#
# Elena's user (hermes) does NOT have read access to this file. That's
# the whole point — moving the API key out of her reach.

# ===== Transport ============================================================

# dry_run | resend | smtp
EMAIL_TRANSPORT=dry_run

# Hard safety belt: while true, the daemon never calls the live transport
# regardless of EMAIL_TRANSPORT. Flip to false ONLY when ready.
EMAIL_DRY_RUN=true

# Required once EMAIL_DRY_RUN=false. RFC 5322 mailbox.
# EMAIL_FROM="David Klippel <david@example.com>"
EMAIL_FROM=

# Optional Reply-To.
# EMAIL_REPLY_TO=

# ===== Rate limit ===========================================================

EMAIL_LIMIT_TZ=local
EMAIL_RESERVATION_TTL_SECONDS=600

# ===== Attachments ==========================================================

EMAIL_MAX_ATTACHMENT_BYTES=10485760
EMAIL_MAX_TOTAL_BYTES=26214400

# ===== Resend ===============================================================

# RESEND_API_KEY=re_xxx

# ===== SMTP =================================================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_STARTTLS=true

# ===== Caller-UID map (future-proofing for multi-tenant) ====================
#
# Maps connecting Unix UID -> caller identity. The daemon resolves callers
# via SO_PEERCRED on the UDS connection — kernel-attested, can't be
# spoofed. Without an explicit entry, the daemon falls back to:
#   uid -> getpwuid(uid).pw_name -> only "hermes" maps to "elena"; rest
#   are rejected as unknown_caller.
#
# To add a new local agent (e.g. winnow-agent) with its own allowlist:
#   CALLER_UID_winnow_agent=1234     # the agent's UID
# and put its policy at /etc/hermes-mailer/allowlists/winnow-agent.yaml.
