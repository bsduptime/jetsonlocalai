# hermes-calendar relay config -> installed to /etc/hermes-calendar/.env
# (root:hermes-calendar-config, mode 0640; the daemon reads it via the config
# group, Elena cannot). DRY-RUN IS THE DEFAULT — nothing is written to a real
# calendar and no invites are sent until CALENDAR_DRY_RUN=false AND Google
# creds are present.

CALENDAR_DRY_RUN=true

CALENDAR_TZ=Asia/Jerusalem
CALENDAR_DEFAULT=family
CALENDAR_DEFAULT_DURATION_MIN=60
CALENDAR_DAILY_LIMIT=20

# These are also set by the systemd unit; kept here for reference/overrides.
# HERMES_CALENDAR_SOCKET=/run/hermes-calendar/sock
# HERMES_CALENDAR_CLIENTS_GROUP=hermes-calendar-clients
# CALENDAR_CONTACTS_FILE=/etc/hermes-calendar/contacts.yaml
# CALENDAR_STATE_DIR=/var/lib/hermes-calendar

# ---- LIVE mode (set CALENDAR_DRY_RUN=false) ----
# pip install -r requirements.txt system-wide first (see setup script --live).
# OAuth *client secret* is read-only config; the *user token* lives in the
# writable state dir (the daemon refreshes it). Bootstrap the token once as
# root (see JETSON-DEPLOY.md) so it lands in the state dir owned correctly.
# CALENDAR_GOOGLE_CREDENTIALS=/etc/hermes-calendar/gcal-oauth-client.json
# CALENDAR_GOOGLE_TOKEN=/var/lib/hermes-calendar/gcal-token.json
# CALENDAR_FAMILY_ID=xxxxxxxx@group.calendar.google.com
