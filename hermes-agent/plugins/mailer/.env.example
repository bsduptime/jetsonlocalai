# Hermes email plugin — secrets and per-deployment settings.
# This file lives at ~/.hermes/email-plugin/.env on the Jetson and is
# read by the email plugin itself (NOT by Hermes' shared .env loader).
# Mode 600. ACL: u:dbexpertai:rw so David can edit without sudo.

# ===== Transport ============================================================

# One of: dry_run | resend | smtp
EMAIL_TRANSPORT=dry_run

# Safety belt: while true, the plugin NEVER calls the live transport,
# regardless of EMAIL_TRANSPORT. Flip to false ONLY when you are sure
# you want real emails to go out.
EMAIL_DRY_RUN=true

# Required as soon as EMAIL_DRY_RUN=false. RFC 5322 mailbox.
# EMAIL_FROM="David Klippel <david@example.com>"
EMAIL_FROM=

# Optional Reply-To. Same format rules as EMAIL_FROM.
# EMAIL_REPLY_TO=

# ===== Rate limit ===========================================================

# Timezone for the daily window. `local` uses the system timezone; or use
# an IANA name like Europe/Berlin or America/New_York.
EMAIL_LIMIT_TZ=local

# How long a `reserved` row can sit before it's reclassified as
# `unknown_post_send` (counted against the cap). Bumps quota only after
# a hard crash so the cap stays honored in worst-case. Default 600s gives
# plenty of headroom for slow SMTP sends with large attachments.
EMAIL_RESERVATION_TTL_SECONDS=600

# ===== Attachments ==========================================================

EMAIL_MAX_ATTACHMENT_BYTES=10485760
EMAIL_MAX_TOTAL_BYTES=26214400

# Colon-separated absolute path prefixes where attachment paths must live.
# Default is /tmp/ only — agent must stage files there before attaching.
EMAIL_ATTACHMENT_ALLOWED_PREFIXES=/tmp/

# ===== Resend ===============================================================

# RESEND_API_KEY=re_xxx

# ===== SMTP =================================================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# Use STARTTLS on port 587 (default). For implicit-TLS port 465 set to false.
# SMTP_STARTTLS=true
