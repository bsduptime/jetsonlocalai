# hermes-calendar relay config. Copy to the plugin config dir as `.env`.
# DRY-RUN IS THE DEFAULT — nothing is written to a real calendar and no
# invites are sent until you set CALENDAR_DRY_RUN=false AND provide Google creds.

CALENDAR_DRY_RUN=true

# Local timezone for resolving/emitting event times.
CALENDAR_TZ=Asia/Jerusalem

# Default calendar label + default event length.
CALENDAR_DEFAULT=family
CALENDAR_DEFAULT_DURATION_MIN=60

# Per-day cap on REAL (non-dry-run) event creations. Dry-run never consumes it.
CALENDAR_DAILY_LIMIT=20

# UDS the plugin talks to (must match the plugin's HERMES_CALENDAR_SOCKET).
HERMES_CALENDAR_SOCKET=/run/hermes-calendar/sock

# Where dry-run artifacts, the rate-limit counter, and the audit log live.
CALENDAR_STATE_DIR=/home/hermes/.hermes/calendar-plugin/state

# Contacts file (YAML if PyYAML installed, else JSON). Names/aliases -> emails.
CALENDAR_CONTACTS_FILE=/home/hermes/.hermes/calendar-plugin/contacts.yaml

# ---- LIVE mode (set CALENDAR_DRY_RUN=false to use) ----
# CALENDAR_GOOGLE_CREDENTIALS=/home/hermes/.hermes/calendar-plugin/gcal-oauth-client.json
# CALENDAR_GOOGLE_TOKEN=/home/hermes/.hermes/calendar-plugin/gcal-token.json
# CALENDAR_FAMILY_ID=xxxxxxxx@group.calendar.google.com
